{
  "name": "clean-architecture-highlighter",
  "displayName": "Clean Architecture Highlighter",
  "description": "Clean architecture Highlighter for VSCode",
  "publisher": "jfrz38",
  "author": {
    "name": "José F. Ruiz",
    "email": "jrz899@inlumine.ual.es"
  },
  "pricing": "Free",
  "version": "0.1.0",
  "packageManager": "pnpm@11.1.3",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.70.0"
  },
  "qna": "marketplace",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1E2D3D",
    "theme": "dark"
  },
  "categories": [
    "Linters",
    "Visualization",
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onStartupFinished"
  ],
  "keywords": [
    "code analysis",
    "clean architecture",
    "dependency validation",
    "static analysis",
    "hexagonal architecture"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jfrz38/clean-architecture-highlighter"
  },
  "bugs": {
    "url": "https://github.com/jfrz38/clean-architecture-highlighter/issues"
  },
  "homepage": "https://github.com/jfrz38/clean-architecture-highlighter#readme",
  "main": "./out/src/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "javascript",
        "aliases": [
          "JavaScript",
          "javascript"
        ],
        "extensions": [
          ".js",
          ".mjs",
          ".cjs"
        ]
      },
      {
        "id": "typescript",
        "aliases": [
          "TypeScript",
          "typescript"
        ],
        "extensions": [
          ".ts",
          ".mts",
          ".cts"
        ]
      },
      {
        "id": "csharp",
        "aliases": [
          "C#",
          "csharp"
        ],
        "extensions": [
          ".cs",
          ".csx"
        ]
      },
      {
        "id": "dart",
        "aliases": [
          "Dart",
          "dart"
        ],
        "extensions": [
          ".dart"
        ]
      },
      {
        "id": "elixir",
        "aliases": [
          "Elixir",
          "elixir"
        ],
        "extensions": [
          ".ex",
          ".exs"
        ]
      },
      {
        "id": "go",
        "aliases": [
          "Go",
          "go",
          "Golang",
          "golang"
        ],
        "extensions": [
          ".go"
        ]
      },
      {
        "id": "groovy",
        "aliases": [
          "Groovy",
          "groovy"
        ],
        "extensions": [
          ".groovy",
          ".gvy",
          ".gy",
          ".gsh"
        ]
      },
      {
        "id": "java",
        "aliases": [
          "Java",
          "java"
        ],
        "extensions": [
          ".java"
        ]
      },
      {
        "id": "kotlin",
        "aliases": [
          "Kotlin",
          "kotlin"
        ],
        "extensions": [
          ".kt",
          ".kts"
        ]
      },
      {
        "id": "lua",
        "aliases": [
          "Lua",
          "lua"
        ],
        "extensions": [
          ".lua"
        ]
      },
      {
        "id": "php",
        "aliases": [
          "PHP",
          "php"
        ],
        "extensions": [
          ".php",
          ".php3",
          ".php4",
          ".php5",
          ".phtml"
        ]
      },
      {
        "id": "python",
        "aliases": [
          "Python",
          "python"
        ],
        "extensions": [
          ".py"
        ]
      },
      {
        "id": "ruby",
        "aliases": [
          "Ruby",
          "ruby"
        ],
        "extensions": [
          ".rb"
        ]
      },
      {
        "id": "rust",
        "aliases": [
          "Rust",
          "rust"
        ],
        "extensions": [
          ".rs"
        ]
      },
      {
        "id": "scala",
        "aliases": [
          "Scala",
          "scala"
        ],
        "extensions": [
          ".scala",
          ".sc"
        ]
      }
    ],
    "configuration": {
      "title": "Clean Architecture Highlighter",
      "properties": {
        "clean-architecture-highlighter.severityLevel": {
          "type": "string",
          "enum": [
            "warning",
            "error",
            "info"
          ],
          "default": "warning",
          "description": "The severity level of the diagnostic messages shown in the editor."
        },
        "clean-architecture-highlighter.sourceFolder": {
          "type": "string",
          "default": "src",
          "description": "The source folder relative to the workspace root."
        },
        "clean-architecture-highlighter.enabledLanguages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "javascript",
            "typescript"
          ],
          "description": "List of VS Code language identifiers that should be analyzed."
        },
        "clean-architecture-highlighter.layers.domain.aliases": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "domain"
          ],
          "description": "List of path aliases or glob patterns that identify the Domain layer."
        },
        "clean-architecture-highlighter.layers.domain.allowedDependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "domain"
          ],
          "description": "List of layers that the Domain layer is permitted to import from."
        },
        "clean-architecture-highlighter.layers.application.aliases": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "application"
          ],
          "description": "List of path aliases or glob patterns that identify the Application layer."
        },
        "clean-architecture-highlighter.layers.application.allowedDependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "domain",
            "application"
          ],
          "description": "List of layers that the Application layer is permitted to import from."
        },
        "clean-architecture-highlighter.layers.infrastructure.aliases": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "infrastructure"
          ],
          "description": "List of path aliases or glob patterns that identify the Infrastructure layer."
        },
        "clean-architecture-highlighter.layers.infrastructure.allowedDependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "domain",
            "application",
            "infrastructure"
          ],
          "description": "List of layers that the Infrastructure layer is permitted to import from."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run clean:compile && pnpm run bundle",
    "compile": "pnpm run compile:scenarios && tsc -b ./",
    "clean:compile": "rimraf out tsconfig.tsbuildinfo && pnpm run compile:scenarios && tsc -b ./",
    "bundle": "esbuild ./src/extension.ts --bundle --outfile=out/src/extension.js --external:vscode --format=cjs --platform=node --target=node16 --minify",
    "compile:scenarios": "tsc -p ../../test/scenarios/tsconfig.json",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src test",
    "test": "pnpm run tests",
    "tests": "pnpm run compile && node out/test/runTest.js",
    "clean:tests": "rimraf out && pnpm run tests",
    "package": "pnpm exec vsce package --no-dependencies"
  },
  "dependencies": {
    "@jfrz38/clean-architecture-highlighter-core": "workspace:*"
  }
}
