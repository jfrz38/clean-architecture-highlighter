{
  "name": "@jfrz38/clean-architecture-highlighter-cli",
  "version": "0.1.0",
  "description": "Command-line checker for Clean Architecture dependency boundaries.",
  "author": "José F. Ruiz <jrz899@inlumine.ual.es>",
  "license": "Apache-2.0",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./out/src/index.d.ts",
  "bin": {
    "clean-arch": "./dist/index.js",
    "clean-architecture-highlighter": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "out/src/**/*.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jfrz38/clean-architecture-highlighter.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/jfrz38/clean-architecture-highlighter/tree/main/packages/cli#readme",
  "keywords": [
    "clean-architecture",
    "architecture",
    "dependency-rule",
    "static-analysis",
    "cli",
    "typescript",
    "javascript",
    "dependency-analysis",
    "architecture-rules",
    "code-quality"
  ],
  "packageManager": "pnpm@11.1.3",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "compile": "pnpm run compile:scenarios && tsc -b ./",
    "clean:compile": "rimraf out dist tsconfig.tsbuildinfo && pnpm run compile:scenarios && tsc -b ./",
    "compile:scenarios": "tsc -p ../../test/scenarios/tsconfig.json",
    "bundle": "node scripts/bundle.cjs",
    "package": "pnpm run clean:compile && pnpm run bundle",
    "prepublishOnly": "pnpm run package",
    "lint": "eslint src test",
    "test": "pnpm run compile && mocha \"out/test/**/*.test.js\" --ui tdd --timeout 10000",
    "check": "node out/src/index.js check",
    "clean:tests": "rimraf out && pnpm run test"
  },
  "devDependencies": {
    "@jfrz38/clean-architecture-highlighter-core": "workspace:*",
    "@types/node": "25.x",
    "commander": "14.0.3"
  }
}
