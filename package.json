{
  "name": "clean-architecture-highlighter-monorepo",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "compile": "pnpm -r --sort run compile",
    "clean:compile": "pnpm -r --sort run clean:compile",
    "lint": "pnpm -r --sort run lint",
    "test": "pnpm -r --sort run test",
    "clean:tests": "pnpm -r --sort run clean:tests",
    "package": "pnpm --filter clean-architecture-highlighter run package"
  },
  "devDependencies": {
    "@types/mocha": "10.0.10",
    "@types/node": "25.x",
    "@types/vscode": "1.70.0",
    "@vscode/test-cli": "0.0.12",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "3.9.1",
    "esbuild": "0.28.0",
    "eslint": "10.1.0",
    "glob": "13.0.6",
    "mocha": "11.7.5",
    "rimraf": "6.1.3",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0"
  }
}
